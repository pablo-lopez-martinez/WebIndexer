										<video data-inline-media data-inline-media-basepath="/105/media/us/macos/sonoma/2023/e6d837c5-8a7e-49d8-b0bd-137b21320db3/anim/swipe-to-reply/" data-inline-media-plugins="AnimLoad, ViewportSource, PlayPauseButton" playsinline muted role="img" aria-label="Animación que muestra el desplazamiento automático hacia arriba en una conversación en Mensajes al tocar la flecha. Se muestra cómo responder directamente a un mensaje de la conversación deslizando hacia la derecha." preload="none"></video>
										<figure class="start-frame" aria-hidden="true" data-anim-lazy-image data-download-area-keyframe='{"disabledWhen":"no-enhanced"}'></figure>
